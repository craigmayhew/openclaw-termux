# syntax=docker/dockerfile:1.7

FROM ubuntu:24.04 AS builder

ARG DEBIAN_FRONTEND=noninteractive
ARG FLUTTER_VERSION=3.24.0
ARG ANDROID_CMDLINE_TOOLS_VERSION=14742923
ARG ANDROID_PLATFORM=35
ARG ANDROID_BUILD_TOOLS=35.0.0
ARG BUILD_UNIVERSAL=1
ARG BUILD_APP_BUNDLE=0

ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64 \
    ANDROID_SDK_ROOT=/opt/android-sdk \
    ANDROID_HOME=/opt/android-sdk \
    FLUTTER_HOME=/opt/flutter \
    PATH=/opt/flutter/bin:/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

SHELL ["/bin/bash", "-lc"]

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    binutils \
    ca-certificates \
    curl \
    file \
    git \
    libglu1-mesa \
    openjdk-17-jdk \
    unzip \
    xz-utils \
    zip \
    zstd \
 && rm -rf /var/lib/apt/lists/*

RUN if ! id -u builder >/dev/null 2>&1; then useradd -m -U builder; fi \
 && mkdir -p /home/builder/.android /home/builder/.pub-cache /home/builder/.gradle /out \
 && touch /home/builder/.android/repositories.cfg \
 && chown -R builder:builder /home/builder /out

RUN mkdir -p /root/.android "${ANDROID_SDK_ROOT}/cmdline-tools" \
 && touch /root/.android/repositories.cfg \
 && curl -fsSL \
      "https://dl.google.com/android/repository/commandlinetools-linux-${ANDROID_CMDLINE_TOOLS_VERSION}_latest.zip" \
      -o /tmp/cmdline-tools.zip \
 && mkdir -p /tmp/cmdline-tools \
 && unzip -q /tmp/cmdline-tools.zip -d /tmp/cmdline-tools \
 && mkdir -p "${ANDROID_SDK_ROOT}/cmdline-tools/latest" \
 && mv /tmp/cmdline-tools/cmdline-tools/* "${ANDROID_SDK_ROOT}/cmdline-tools/latest/" \
 && rm -rf /tmp/cmdline-tools /tmp/cmdline-tools.zip

RUN set -euo pipefail; \
    install_sdk_pkg() { \
      local pkg="$1"; \
      local attempt; \
      for attempt in 1 2 3; do \
        echo "==> Installing ${pkg} (attempt ${attempt}/3)"; \
        if sdkmanager --sdk_root="${ANDROID_SDK_ROOT}" "${pkg}"; then \
          return 0; \
        fi; \
        echo "sdkmanager failed for ${pkg}; clearing temp/cache before retry"; \
        rm -rf "${ANDROID_SDK_ROOT}/.temp" /tmp/android-* /tmp/package*.zip || true; \
        if [ -d /root/.android/cache ]; then \
          find /root/.android/cache -mindepth 1 -maxdepth 1 -exec rm -rf {} + || true; \
        fi; \
        sleep 2; \
      done; \
      echo "ERROR: could not install ${pkg} after 3 attempts" >&2; \
      return 1; \
    }; \
    yes | sdkmanager --sdk_root="${ANDROID_SDK_ROOT}" --licenses >/dev/null || [[ ${PIPESTATUS[1]} -eq 0 ]]; \
    install_sdk_pkg "platform-tools"; \
    install_sdk_pkg "platforms;android-${ANDROID_PLATFORM}"; \
    install_sdk_pkg "build-tools;${ANDROID_BUILD_TOOLS}"; \
    install_sdk_pkg "ndk;23.1.7779620"; \
    install_sdk_pkg "cmake;3.22.1"; \
    chown -R builder:builder "${ANDROID_SDK_ROOT}"

RUN curl -fsSL \
      "https://storage.googleapis.com/flutter_infra_release/releases/stable/linux/flutter_linux_${FLUTTER_VERSION}-stable.tar.xz" \
      -o /tmp/flutter.tar.xz \
 && tar --no-same-owner -xJf /tmp/flutter.tar.xz -C /opt \
 && rm -f /tmp/flutter.tar.xz \
 && chown -R builder:builder "${FLUTTER_HOME}"

WORKDIR /src
COPY --chown=builder:builder . /src

USER builder
ENV HOME=/home/builder \
    PUB_CACHE=/home/builder/.pub-cache \
    GRADLE_USER_HOME=/home/builder/.gradle \
    ANDROID_USER_HOME=/home/builder/.android

RUN git config --global --add safe.directory "${FLUTTER_HOME}" \
 && flutter --disable-analytics \
 && chmod +x scripts/*.sh \
 && bash scripts/fetch-proot-binaries.sh \
 && cd flutter_app \
 && flutter pub get \
 && printf 'sdk.dir=%s\nflutter.sdk=%s\n' "${ANDROID_SDK_ROOT}" "${FLUTTER_HOME}" > android/local.properties \
 && flutter build apk --release --split-per-abi \
 && mkdir -p /out \
 && cp build/app/outputs/flutter-apk/app-arm64-v8a-release.apk /out/OpenClaw-arm64-v8a.apk \
 && if [ -f build/app/outputs/flutter-apk/app-armeabi-v7a-release.apk ]; then \
      cp build/app/outputs/flutter-apk/app-armeabi-v7a-release.apk /out/OpenClaw-armeabi-v7a.apk; \
    fi \
 && if [ -f build/app/outputs/flutter-apk/app-x86_64-release.apk ]; then \
      cp build/app/outputs/flutter-apk/app-x86_64-release.apk /out/OpenClaw-x86_64.apk; \
    fi \
 && if [ "${BUILD_UNIVERSAL}" = "1" ]; then \
      flutter build apk --release; \
      cp build/app/outputs/flutter-apk/app-release.apk /out/OpenClaw-universal.apk; \
    fi \
 && if [ "${BUILD_APP_BUNDLE}" = "1" ]; then \
      flutter build appbundle --release; \
      cp build/app/outputs/bundle/release/app-release.aab /out/OpenClaw.aab; \
    fi

FROM scratch AS export
COPY --from=builder /out/ /
